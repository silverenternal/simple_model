{
  "schema_version": "2.0",
  "macros": [
    {
      "id": "adopt_repo",
      "type": "exec",
      "description": "Run repo adoption facts and create a macro optimization plan.",
      "risk": "low",
      "auto_apply": true,
      "inputs": [
        "repo_root"
      ],
      "writes": [
        "generated/optimization/*.json",
        "generated/optimization/*.md"
      ],
      "validations": [
        "optimization_plan.sh --json"
      ],
      "rollback": "Delete generated optimization reports.",
      "execution_tier": "exec_readonly"
    },
    {
      "id": "component_extract_advisory",
      "type": "code",
      "description": "Suggest component extraction from project structure and semantic graph clusters.",
      "risk": "medium",
      "auto_apply": false,
      "inputs": [
        "project_structure",
        "semantic_ir"
      ],
      "writes": [
        "generated/optimization/*.json"
      ],
      "validations": [
        "macro_simulate.sh"
      ],
      "rollback": "Delete generated advisory reports.",
      "execution_tier": "advisory"
    },
    {
      "id": "contract_export_sync",
      "type": "code",
      "description": "Synchronize component exports with contract graph operations.",
      "risk": "medium",
      "auto_apply": false,
      "inputs": [
        "contract_graph",
        "semantic_ir"
      ],
      "writes": [
        "struct.json"
      ],
      "validations": [
        "release_contract.sh"
      ],
      "rollback": "Restore struct backup.",
      "execution_tier": "safe_codemod"
    },
    {
      "id": "dependency_inversion_advisory",
      "type": "code",
      "description": "Suggest dependency inversion where high-level components import lower-level implementation details.",
      "risk": "medium",
      "auto_apply": false,
      "inputs": [
        "workspace_graph",
        "import_graph_scan"
      ],
      "writes": [
        "generated/optimization/*.json"
      ],
      "validations": [
        "policy_eval.sh"
      ],
      "rollback": "Delete generated advisory reports.",
      "execution_tier": "advisory"
    },
    {
      "id": "normalize_component_exports",
      "type": "code",
      "description": "Synchronize component exports with deterministic interface_scan discoveries.",
      "risk": "medium",
      "auto_apply": true,
      "inputs": [
        "struct",
        "interface_scan"
      ],
      "writes": [
        "struct.json"
      ],
      "validations": [
        "./bootstrap.sh --interface-scan <root> --json"
      ],
      "rollback": "Restore the original struct.json backup captured by macro_exec.",
      "execution_tier": "struct_only"
    },
    {
      "id": "orphan_file_adoption",
      "type": "code",
      "description": "Adopt unmanaged source files into proposed struct components.",
      "risk": "medium",
      "auto_apply": false,
      "inputs": [
        "adoption_audit",
        "project_structure"
      ],
      "writes": [
        "struct.json"
      ],
      "validations": [
        "adoption_audit.sh"
      ],
      "rollback": "Restore struct backup.",
      "execution_tier": "safe_codemod"
    },
    {
      "id": "package_boundary_repair",
      "type": "code",
      "description": "Repair struct dependency metadata for package boundary drift.",
      "risk": "medium",
      "auto_apply": false,
      "inputs": [
        "workspace_graph",
        "import_graph_scan"
      ],
      "writes": [
        "struct.json"
      ],
      "validations": [
        "pr_gate.sh"
      ],
      "rollback": "Restore struct backup.",
      "execution_tier": "safe_codemod"
    },
    {
      "id": "reduce_arch_debt",
      "type": "exec",
      "description": "Plan low-risk architecture debt reductions using deterministic findings.",
      "risk": "medium",
      "auto_apply": false,
      "inputs": [
        "architecture_debt"
      ],
      "writes": [
        "generated/optimization/*.json",
        "generated/optimization/*.md"
      ],
      "validations": [
        "architecture_debt.sh --json"
      ],
      "rollback": "Delete generated optimization reports.",
      "execution_tier": "advisory"
    },
    {
      "id": "route_grouping",
      "type": "code",
      "description": "Group framework route surfaces under owning components and contracts.",
      "risk": "medium",
      "auto_apply": false,
      "inputs": [
        "framework_surfaces",
        "semantic_ir"
      ],
      "writes": [
        "struct.json"
      ],
      "validations": [
        "semantic_interface_ir.sh"
      ],
      "rollback": "Restore struct backup.",
      "execution_tier": "safe_codemod"
    },
    {
      "id": "split_struct_include",
      "type": "code",
      "description": "Split a large single-file struct.json into root includes plus per-module fragments.",
      "risk": "low",
      "auto_apply": true,
      "inputs": [
        "struct"
      ],
      "writes": [
        "struct.json",
        "struct.modules/*.json"
      ],
      "validations": [
        "./bootstrap.sh --validate"
      ],
      "rollback": "Restore the original struct.json and remove generated struct.modules fragments.",
      "execution_tier": "struct_only"
    },
    {
      "id": "stabilize_interfaces",
      "type": "exec",
      "description": "Plan export/import struct synchronization from scanned code interfaces.",
      "risk": "medium",
      "auto_apply": true,
      "inputs": [
        "struct",
        "interface_scan",
        "import_graph_scan"
      ],
      "writes": [
        "generated/optimization/*.json"
      ],
      "validations": [
        "macro_exec.sh --dry-run"
      ],
      "rollback": "Delete generated optimization reports.",
      "execution_tier": "exec_readonly"
    },
    {
      "id": "sync_struct_imports_from_code_facts",
      "type": "code",
      "description": "Synchronize component imports with deterministic import_graph_scan edges.",
      "risk": "medium",
      "auto_apply": true,
      "inputs": [
        "struct",
        "import_graph_scan"
      ],
      "writes": [
        "struct.json"
      ],
      "validations": [
        "./bootstrap.sh --pr-gate <root> --json"
      ],
      "rollback": "Restore the original struct.json backup captured by macro_exec.",
      "execution_tier": "struct_only"
    },
    {
      "id": "test_relocation_advisory",
      "type": "exec",
      "description": "Suggest test placement improvements from test graph gaps.",
      "risk": "low",
      "auto_apply": false,
      "inputs": [
        "test_graph"
      ],
      "writes": [
        "generated/optimization/*.json"
      ],
      "validations": [
        "test_graph.sh"
      ],
      "rollback": "Delete generated advisory reports.",
      "execution_tier": "advisory"
    }
  ],
  "packs": [
    {
      "name": "semantic-refactor",
      "version": "1.0.0",
      "macros": [
        "component_extract_advisory",
        "dependency_inversion_advisory",
        "package_boundary_repair",
        "orphan_file_adoption",
        "route_grouping",
        "contract_export_sync",
        "test_relocation_advisory",
        "split_struct_include"
      ],
      "languages": [
        "python",
        "typescript",
        "javascript",
        "go",
        "rust"
      ],
      "frameworks": [
        "express",
        "fastapi",
        "go_net_http"
      ],
      "parser_requirements": [
        "semantic_interface_ir_v2",
        "framework_surface_extractors"
      ],
      "risk": "medium",
      "fixture_coverage": [
        "tests/test_v07_roadmap.sh"
      ]
    }
  ],
  "execution_tiers": {
    "advisory": {
      "writes_allowed": false,
      "simulation_required": false,
      "policy_required": false
    },
    "exec_readonly": {
      "writes_allowed": false,
      "simulation_required": false,
      "policy_required": false
    },
    "struct_only": {
      "writes_allowed": true,
      "simulation_required": false,
      "policy_required": true
    },
    "safe_codemod": {
      "writes_allowed": true,
      "simulation_required": true,
      "policy_required": true
    },
    "risky_codemod": {
      "writes_allowed": true,
      "simulation_required": true,
      "policy_required": true,
      "approval_required": true
    }
  }
}
