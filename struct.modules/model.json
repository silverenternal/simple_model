{
  "schema_version": "3.0",
  "description": "Simple Model — 多任务/多模态项目架构：模块定义、调用关系、数据流",
  "conventions": {
    "depends_on": "该服务直接调用的上游服务列表（仅记录直接调用，不展开传递依赖）",
    "produces": "该服务产出的核心 artifact / 数据，串联起来即完整数据流",
    "optional": "true 表示按需启用的扩展服务，false 或缺省为核心服务",
    "pipeline.stages": "按 order 升序执行的顺序阶段，构成完整训练-部署的 happy path",
    "pipeline.cross_cutting": "横切关注点：不参与主流程串行顺序，而是在多个阶段并行注入",
    "supported_tasks": "架构显式支持的任务清单，是 Auto* 派发的依据"
  },
  "phases": [
    {
      "phase": "configure",
      "order": 1,
      "mode": "sequential",
      "description": "加载并校验配置，按任务名拉取 AutoConfig",
      "core_components": [
        "ConfigLoader",
        "ConfigComposer",
        "ConfigValidator",
        "TaskRegistry",
        "AutoConfig"
      ]
    },
    {
      "phase": "prepare_data",
      "order": 2,
      "mode": "sequential",
      "description": "按任务拉取 Processor，加载、解析、切分、组装 batch",
      "core_components": [
        "AutoProcessor",
        "DataLoader",
        "DataParser",
        "DataSplitter",
        "Tokenizer",
        "ImageProcessor",
        "AudioFeatureExtractor",
        "Collator"
      ],
      "optional_components": [
        "DataCleaner",
        "VideoProcessor",
        "DataAugmenter",
        "DataCache",
        "DataVersion"
      ]
    },
    {
      "phase": "build_model",
      "order": 3,
      "mode": "sequential",
      "description": "按任务从 ModelRegistry 拉取 Backbone+Neck+Head，组装模型与优化器",
      "core_components": [
        "AutoModel",
        "ModelRegistry",
        "Backbone",
        "Neck",
        "Head",
        "ModelBuilder",
        "LossFunction",
        "Optimizer",
        "LRScheduler"
      ]
    },
    {
      "phase": "init_distributed",
      "order": 4,
      "mode": "select_one",
      "description": "按配置挑选一种分布式后端初始化进程组",
      "core_components": [
        "ClusterMonitor",
        "RankSync"
      ],
      "select_one_of": [
        "DDPLauncher",
        "FSDPManager",
        "DeepSpeedEngine",
        "TensorParallel"
      ]
    },
    {
      "phase": "train",
      "order": 5,
      "mode": "sequential",
      "description": "训练主循环，含混合精度、梯度管理、EMA、回调与检查点",
      "core_components": [
        "Trainer",
        "MixedPrecision",
        "Callback",
        "Checkpoint"
      ],
      "optional_components": [
        "GradientAccumulator",
        "GradientClipper",
        "EMA"
      ]
    },
    {
      "phase": "verify",
      "order": 6,
      "mode": "sequential",
      "description": "按任务路由到对应指标集并生成报告",
      "core_components": [
        "Validator",
        "TaskEvaluator",
        "MetricsCalculator",
        "Reporter"
      ],
      "optional_components": [
        "NLPMetrics",
        "VisionMetrics",
        "SpeechMetrics",
        "RankingMetrics",
        "GenerationMetrics",
        "Benchmark",
        "RobustnessProbe"
      ]
    },
    {
      "phase": "compress",
      "order": 7,
      "mode": "select_subset",
      "description": "按需执行量化、剪枝、蒸馏、图优化并导出跨平台格式",
      "core_components": [
        "Exporter"
      ],
      "select_subset_of": [
        "Quantizer",
        "Pruner",
        "Distiller",
        "GraphOptimizer"
      ]
    },
    {
      "phase": "deploy",
      "order": 8,
      "mode": "sequential",
      "description": "上线推理服务、暴露 API、灰度发布并接入漂移监控",
      "core_components": [
        "InferenceEngine",
        "ModelServer",
        "APIGateway"
      ],
      "optional_components": [
        "CanaryDeployer",
        "DriftDetector"
      ]
    }
  ],
  "cross_cutting": [
    {
      "name": "tracking",
      "description": "贯穿全程的实验追踪、产物记录与可视化",
      "injects_into": [
        "configure",
        "train",
        "verify",
        "compress",
        "deploy"
      ],
      "components": [
        "ExperimentTracker",
        "MetricRecorder",
        "ArtifactStore",
        "Visualizer"
      ]
    },
    {
      "name": "repro",
      "description": "贯穿全程的可复现性保障：种子、环境快照、依赖锁、审计",
      "injects_into": [
        "configure",
        "prepare_data",
        "train",
        "verify"
      ],
      "components": [
        "SeedManager",
        "EnvSnapshot",
        "AuditLogger"
      ]
    },
    {
      "name": "profile",
      "description": "在 train 与 deploy 阶段按需启用的性能与显存分析",
      "injects_into": [
        "train",
        "deploy"
      ],
      "default_enabled": false,
      "components": [
        "Profiler",
        "MemoryProfiler",
        "BottleneckAnalyzer"
      ]
    },
    {
      "name": "hpo",
      "description": "外层循环：包裹 configure→train→verify，按 trial 反复执行挑选最优超参",
      "injects_into": [
        "train",
        "verify"
      ],
      "default_enabled": false,
      "components": [
        "SearchSpace",
        "SweepGenerator",
        "TrialScheduler",
        "HPOTuner",
        "EarlyStopper",
        "NASEngine"
      ]
    },
    {
      "name": "pipeline",
      "description": "工作流编排：声明 DAG、缓存中间产物、按策略重试",
      "injects_into": [
        "configure",
        "prepare_data",
        "build_model",
        "train",
        "verify",
        "compress",
        "deploy"
      ],
      "components": [
        "WorkflowScheduler",
        "TaskDAG",
        "PipelineCache",
        "RetryPolicy"
      ]
    },
    {
      "name": "test",
      "description": "CI 与合并前门禁处运行的测试与质量门槛",
      "injects_into": [
        "verify"
      ],
      "components": [
        "UnitTest",
        "IntegrationTest",
        "RegressionTest",
        "QualityGate"
      ]
    }
  ],
  "modules": [
    {
      "name": "model",
      "description": "模型组件库：Backbone + Neck + Head 可组合架构，模型注册中心",
      "components": [
        {
          "name": "Backbone",
          "description": "用于特征提取的主干网络（ResNet / ViT / BERT / Wav2Vec2 / GCN ...）",
          "exports": [
            "feature_maps"
          ],
          "imports": [],
          "todos": [
            {
              "task": "接入 timm / torchvision 的视觉 Backbone",
              "priority": "high",
              "id": "backbone_1",
              "status": "done",
              "blocks": [
                "model_builder_1"
              ]
            },
            {
              "task": "接入 transformers 的 NLP Backbone",
              "priority": "high",
              "id": "backbone_2",
              "status": "done"
            },
            {
              "task": "支持冻结/解冻特定 stage 的参数",
              "priority": "medium",
              "id": "backbone_3",
              "status": "done"
            }
          ]
        },
        {
          "name": "Neck",
          "description": "用于连接 Backbone 与 Head 的中间模块（FPN / ASPP / Adapter / Q-Former ...）",
          "exports": [
            "neck_features"
          ],
          "imports": [],
          "todos": [
            {
              "task": "实现 FPN / ASPP 等视觉 Neck",
              "priority": "medium",
              "id": "neck_1",
              "status": "done"
            },
            {
              "task": "实现 LoRA / Adapter 等参数高效迁移模块",
              "priority": "medium",
              "id": "neck_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "Head",
          "description": "用于任务特定的输出层（分类 / 检测 / 分割 / 生成 / 检索 ...）",
          "exports": [
            "task_output"
          ],
          "imports": [],
          "todos": [
            {
              "task": "实现分类 / 检测 / 分割三类基础 Head",
              "priority": "high",
              "id": "head_1",
              "status": "done",
              "blocks": [
                "model_builder_1"
              ]
            },
            {
              "task": "实现 LM Head（含 tied weights）",
              "priority": "medium",
              "id": "head_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "Initializer",
          "description": "用于参数初始化策略（Xavier / Kaiming / DeepSpeed-init）",
          "imports": [],
          "exports": [
            "initializer"
          ]
        },
        {
          "name": "ModelRegistry",
          "description": "用于按名称注册与查找模型架构（timm / transformers 风格）",
          "imports": [],
          "todos": [
            {
              "task": "实现 @register 装饰器注册模型",
              "priority": "high",
              "id": "model_registry_1",
              "status": "done",
              "blocks": [
                "model_builder_1"
              ]
            },
            {
              "task": "支持按字符串名动态构建模型",
              "priority": "high",
              "id": "model_registry_2",
              "status": "done"
            }
          ],
          "exports": [
            "model_registry"
          ]
        },
        {
          "name": "ModelBuilder",
          "description": "用于按配置组装 Backbone + Neck + Head，构造完整模型",
          "exports": [
            "model"
          ],
          "imports": [
            "ModelRegistry",
            "Backbone",
            "Neck",
            "Head",
            "Initializer"
          ],
          "todos": [
            {
              "task": "按 config 拼装 Backbone→Neck→Head 并返回完整模型",
              "priority": "high",
              "id": "model_builder_1",
              "status": "done",
              "blocks": [
                "trainer_1"
              ]
            },
            {
              "task": "支持从 yaml/json 配置直接构造",
              "priority": "medium",
              "id": "model_builder_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "LossFunction",
          "description": "用于任务特定的损失函数（CE / Focal / Dice / CTC / Contrastive ...）",
          "exports": [
            "loss_value"
          ],
          "imports": [
            "TaskRegistry"
          ],
          "todos": [
            {
              "task": "按 task 名路由到对应 loss",
              "priority": "high",
              "id": "loss_function_1",
              "status": "done",
              "blocks": [
                "trainer_1"
              ]
            },
            {
              "task": "支持 label smoothing / class weighting",
              "priority": "medium",
              "id": "loss_function_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "Optimizer",
          "description": "用于定义模型训练所用的优化器及其参数",
          "imports": [],
          "todos": [
            {
              "task": "实现 AdamW / SGD / Lion 等基础优化器",
              "priority": "high",
              "id": "optimizer_1",
              "status": "done"
            },
            {
              "task": "支持 per-layer lr / weight decay 分组",
              "priority": "medium",
              "id": "optimizer_2",
              "status": "done"
            }
          ],
          "exports": [
            "optimizer"
          ]
        },
        {
          "name": "LRScheduler",
          "description": "用于定义学习率调度策略（warmup / cosine / plateau）",
          "imports": [
            "Optimizer"
          ],
          "exports": [
            "lr_scheduler"
          ]
        },
        {
          "name": "ModelHub",
          "description": "用于下载、上传和分享预训练模型权重",
          "exports": [
            "pretrained_weights"
          ],
          "imports": [
            "ModelRegistry"
          ],
          "optional": true
        }
      ]
    }
  ]
}
