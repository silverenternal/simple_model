{
  "schema_version": "3.0",
  "description": "Simple Model — 多任务/多模态项目架构：模块定义、调用关系、数据流",
  "conventions": {
    "depends_on": "该服务直接调用的上游服务列表（仅记录直接调用，不展开传递依赖）",
    "produces": "该服务产出的核心 artifact / 数据，串联起来即完整数据流",
    "optional": "true 表示按需启用的扩展服务，false 或缺省为核心服务",
    "pipeline.stages": "按 order 升序执行的顺序阶段，构成完整训练-部署的 happy path",
    "pipeline.cross_cutting": "横切关注点：不参与主流程串行顺序，而是在多个阶段并行注入",
    "supported_tasks": "架构显式支持的任务清单，是 Auto* 派发的依据"
  },
  "phases": [
    {
      "phase": "configure",
      "order": 1,
      "mode": "sequential",
      "description": "加载并校验配置，按任务名拉取 AutoConfig",
      "core_components": [
        "ConfigLoader",
        "ConfigComposer",
        "ConfigValidator",
        "TaskRegistry",
        "AutoConfig"
      ]
    },
    {
      "phase": "prepare_data",
      "order": 2,
      "mode": "sequential",
      "description": "按任务拉取 Processor，加载、解析、切分、组装 batch",
      "core_components": [
        "AutoProcessor",
        "DataLoader",
        "DataParser",
        "DataSplitter",
        "Tokenizer",
        "ImageProcessor",
        "AudioFeatureExtractor",
        "Collator"
      ],
      "optional_components": [
        "DataCleaner",
        "VideoProcessor",
        "DataAugmenter",
        "DataCache",
        "DataVersion"
      ]
    },
    {
      "phase": "build_model",
      "order": 3,
      "mode": "sequential",
      "description": "按任务从 ModelRegistry 拉取 Backbone+Neck+Head，组装模型与优化器",
      "core_components": [
        "AutoModel",
        "ModelRegistry",
        "Backbone",
        "Neck",
        "Head",
        "ModelBuilder",
        "LossFunction",
        "Optimizer",
        "LRScheduler"
      ]
    },
    {
      "phase": "init_distributed",
      "order": 4,
      "mode": "select_one",
      "description": "按配置挑选一种分布式后端初始化进程组",
      "core_components": [
        "ClusterMonitor",
        "RankSync"
      ],
      "select_one_of": [
        "DDPLauncher",
        "FSDPManager",
        "DeepSpeedEngine",
        "TensorParallel"
      ]
    },
    {
      "phase": "train",
      "order": 5,
      "mode": "sequential",
      "description": "训练主循环，含混合精度、梯度管理、EMA、回调与检查点",
      "core_components": [
        "Trainer",
        "MixedPrecision",
        "Callback",
        "Checkpoint"
      ],
      "optional_components": [
        "GradientAccumulator",
        "GradientClipper",
        "EMA"
      ]
    },
    {
      "phase": "verify",
      "order": 6,
      "mode": "sequential",
      "description": "按任务路由到对应指标集并生成报告",
      "core_components": [
        "Validator",
        "TaskEvaluator",
        "MetricsCalculator",
        "Reporter"
      ],
      "optional_components": [
        "NLPMetrics",
        "VisionMetrics",
        "SpeechMetrics",
        "RankingMetrics",
        "GenerationMetrics",
        "Benchmark",
        "RobustnessProbe"
      ]
    },
    {
      "phase": "compress",
      "order": 7,
      "mode": "select_subset",
      "description": "按需执行量化、剪枝、蒸馏、图优化并导出跨平台格式",
      "core_components": [
        "Exporter"
      ],
      "select_subset_of": [
        "Quantizer",
        "Pruner",
        "Distiller",
        "GraphOptimizer"
      ]
    },
    {
      "phase": "deploy",
      "order": 8,
      "mode": "sequential",
      "description": "上线推理服务、暴露 API、灰度发布并接入漂移监控",
      "core_components": [
        "InferenceEngine",
        "ModelServer",
        "APIGateway"
      ],
      "optional_components": [
        "CanaryDeployer",
        "DriftDetector"
      ]
    }
  ],
  "cross_cutting": [
    {
      "name": "tracking",
      "description": "贯穿全程的实验追踪、产物记录与可视化",
      "injects_into": [
        "configure",
        "train",
        "verify",
        "compress",
        "deploy"
      ],
      "components": [
        "ExperimentTracker",
        "MetricRecorder",
        "ArtifactStore",
        "Visualizer"
      ]
    },
    {
      "name": "repro",
      "description": "贯穿全程的可复现性保障：种子、环境快照、依赖锁、审计",
      "injects_into": [
        "configure",
        "prepare_data",
        "train",
        "verify"
      ],
      "components": [
        "SeedManager",
        "EnvSnapshot",
        "AuditLogger"
      ]
    },
    {
      "name": "profile",
      "description": "在 train 与 deploy 阶段按需启用的性能与显存分析",
      "injects_into": [
        "train",
        "deploy"
      ],
      "default_enabled": false,
      "components": [
        "Profiler",
        "MemoryProfiler",
        "BottleneckAnalyzer"
      ]
    },
    {
      "name": "hpo",
      "description": "外层循环：包裹 configure→train→verify，按 trial 反复执行挑选最优超参",
      "injects_into": [
        "train",
        "verify"
      ],
      "default_enabled": false,
      "components": [
        "SearchSpace",
        "SweepGenerator",
        "TrialScheduler",
        "HPOTuner",
        "EarlyStopper",
        "NASEngine"
      ]
    },
    {
      "name": "pipeline",
      "description": "工作流编排：声明 DAG、缓存中间产物、按策略重试",
      "injects_into": [
        "configure",
        "prepare_data",
        "build_model",
        "train",
        "verify",
        "compress",
        "deploy"
      ],
      "components": [
        "WorkflowScheduler",
        "TaskDAG",
        "PipelineCache",
        "RetryPolicy"
      ]
    },
    {
      "name": "test",
      "description": "CI 与合并前门禁处运行的测试与质量门槛",
      "injects_into": [
        "verify"
      ],
      "components": [
        "UnitTest",
        "IntegrationTest",
        "RegressionTest",
        "QualityGate"
      ]
    }
  ],
  "modules": [
    {
      "name": "train",
      "description": "训练引擎：训练循环、混合精度、回调系统、梯度管理",
      "components": [
        {
          "name": "MixedPrecision",
          "description": "用于 fp16 / bf16 / fp8 混合精度训练以加速并节省显存",
          "exports": [
            "scaled_loss"
          ],
          "imports": []
        },
        {
          "name": "GradientAccumulator",
          "description": "用于累积多步梯度以模拟大 batch 训练",
          "exports": [
            "accumulated_grad"
          ],
          "imports": [],
          "optional": true
        },
        {
          "name": "GradientClipper",
          "description": "用于梯度裁剪以避免训练发散",
          "imports": [],
          "optional": true,
          "exports": [
            "gradient_clipper"
          ]
        },
        {
          "name": "EMA",
          "description": "用于维护模型参数的指数移动平均以稳定评估性能",
          "exports": [
            "ema_model"
          ],
          "imports": [],
          "optional": true
        },
        {
          "name": "Callback",
          "description": "用于在 epoch/step 关键节点插入自定义逻辑（早停、动态超参等）",
          "imports": [],
          "exports": [
            "callback"
          ]
        },
        {
          "name": "Trainer",
          "description": "用于执行模型的前向、反向与梯度更新主循环",
          "exports": [
            "trained_model",
            "training_state"
          ],
          "imports": [
            "AutoConfig",
            "AutoModel",
            "AutoProcessor",
            "LossFunction",
            "Optimizer",
            "LRScheduler",
            "Collator",
            "MixedPrecision",
            "GradientAccumulator",
            "GradientClipper",
            "EMA",
            "Callback",
            "SeedManager"
          ],
          "todos": [
            {
              "task": "实现 train loop：forward → loss → backward → step",
              "priority": "high",
              "id": "trainer_1",
              "status": "done",
              "blocks": [
                "trainer_2",
                "trainer_3"
              ]
            },
            {
              "task": "处理梯度累积（accumulation_steps）",
              "priority": "high",
              "id": "trainer_2",
              "status": "done",
              "blocks": [
                "trainer_3"
              ]
            },
            {
              "task": "处理 mixed precision（autocast + GradScaler）",
              "priority": "high",
              "id": "trainer_3",
              "status": "done"
            },
            {
              "task": "实现 eval loop 与 validation 调度",
              "priority": "medium",
              "id": "trainer_4",
              "status": "done"
            },
            {
              "task": "接入 DDP / FSDP 的 all-reduce 钩子",
              "priority": "medium",
              "id": "trainer_5",
              "status": "done"
            },
            {
              "task": "支持 resume from checkpoint",
              "priority": "medium",
              "id": "trainer_6",
              "status": "done"
            }
          ]
        },
        {
          "name": "Checkpoint",
          "description": "用于保存、加载与轮转模型检查点",
          "exports": [
            "checkpoint_artifact"
          ],
          "imports": [
            "Trainer"
          ]
        }
      ]
    }
  ]
}
