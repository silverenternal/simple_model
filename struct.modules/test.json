{
  "schema_version": "3.0",
  "description": "Simple Model — 多任务/多模态项目架构：模块定义、调用关系、数据流",
  "conventions": {
    "depends_on": "该服务直接调用的上游服务列表（仅记录直接调用，不展开传递依赖）",
    "produces": "该服务产出的核心 artifact / 数据，串联起来即完整数据流",
    "optional": "true 表示按需启用的扩展服务，false 或缺省为核心服务",
    "pipeline.stages": "按 order 升序执行的顺序阶段，构成完整训练-部署的 happy path",
    "pipeline.cross_cutting": "横切关注点：不参与主流程串行顺序，而是在多个阶段并行注入",
    "supported_tasks": "架构显式支持的任务清单，是 Auto* 派发的依据"
  },
  "phases": [
    {
      "phase": "configure",
      "order": 1,
      "mode": "sequential",
      "description": "加载并校验配置，按任务名拉取 AutoConfig",
      "core_components": [
        "ConfigLoader",
        "ConfigComposer",
        "ConfigValidator",
        "TaskRegistry",
        "AutoConfig"
      ]
    },
    {
      "phase": "prepare_data",
      "order": 2,
      "mode": "sequential",
      "description": "按任务拉取 Processor，加载、解析、切分、组装 batch",
      "core_components": [
        "AutoProcessor",
        "DataLoader",
        "DataParser",
        "DataSplitter",
        "Tokenizer",
        "ImageProcessor",
        "AudioFeatureExtractor",
        "Collator"
      ],
      "optional_components": [
        "DataCleaner",
        "VideoProcessor",
        "DataAugmenter",
        "DataCache",
        "DataVersion"
      ]
    },
    {
      "phase": "build_model",
      "order": 3,
      "mode": "sequential",
      "description": "按任务从 ModelRegistry 拉取 Backbone+Neck+Head，组装模型与优化器",
      "core_components": [
        "AutoModel",
        "ModelRegistry",
        "Backbone",
        "Neck",
        "Head",
        "ModelBuilder",
        "LossFunction",
        "Optimizer",
        "LRScheduler"
      ]
    },
    {
      "phase": "init_distributed",
      "order": 4,
      "mode": "select_one",
      "description": "按配置挑选一种分布式后端初始化进程组",
      "core_components": [
        "ClusterMonitor",
        "RankSync"
      ],
      "select_one_of": [
        "DDPLauncher",
        "FSDPManager",
        "DeepSpeedEngine",
        "TensorParallel"
      ]
    },
    {
      "phase": "train",
      "order": 5,
      "mode": "sequential",
      "description": "训练主循环，含混合精度、梯度管理、EMA、回调与检查点",
      "core_components": [
        "Trainer",
        "MixedPrecision",
        "Callback",
        "Checkpoint"
      ],
      "optional_components": [
        "GradientAccumulator",
        "GradientClipper",
        "EMA"
      ]
    },
    {
      "phase": "verify",
      "order": 6,
      "mode": "sequential",
      "description": "按任务路由到对应指标集并生成报告",
      "core_components": [
        "Validator",
        "TaskEvaluator",
        "MetricsCalculator",
        "Reporter"
      ],
      "optional_components": [
        "NLPMetrics",
        "VisionMetrics",
        "SpeechMetrics",
        "RankingMetrics",
        "GenerationMetrics",
        "Benchmark",
        "RobustnessProbe"
      ]
    },
    {
      "phase": "compress",
      "order": 7,
      "mode": "select_subset",
      "description": "按需执行量化、剪枝、蒸馏、图优化并导出跨平台格式",
      "core_components": [
        "Exporter"
      ],
      "select_subset_of": [
        "Quantizer",
        "Pruner",
        "Distiller",
        "GraphOptimizer"
      ]
    },
    {
      "phase": "deploy",
      "order": 8,
      "mode": "sequential",
      "description": "上线推理服务、暴露 API、灰度发布并接入漂移监控",
      "core_components": [
        "InferenceEngine",
        "ModelServer",
        "APIGateway"
      ],
      "optional_components": [
        "CanaryDeployer",
        "DriftDetector"
      ]
    }
  ],
  "cross_cutting": [
    {
      "name": "tracking",
      "description": "贯穿全程的实验追踪、产物记录与可视化",
      "injects_into": [
        "configure",
        "train",
        "verify",
        "compress",
        "deploy"
      ],
      "components": [
        "ExperimentTracker",
        "MetricRecorder",
        "ArtifactStore",
        "Visualizer"
      ]
    },
    {
      "name": "repro",
      "description": "贯穿全程的可复现性保障：种子、环境快照、依赖锁、审计",
      "injects_into": [
        "configure",
        "prepare_data",
        "train",
        "verify"
      ],
      "components": [
        "SeedManager",
        "EnvSnapshot",
        "AuditLogger"
      ]
    },
    {
      "name": "profile",
      "description": "在 train 与 deploy 阶段按需启用的性能与显存分析",
      "injects_into": [
        "train",
        "deploy"
      ],
      "default_enabled": false,
      "components": [
        "Profiler",
        "MemoryProfiler",
        "BottleneckAnalyzer"
      ]
    },
    {
      "name": "hpo",
      "description": "外层循环：包裹 configure→train→verify，按 trial 反复执行挑选最优超参",
      "injects_into": [
        "train",
        "verify"
      ],
      "default_enabled": false,
      "components": [
        "SearchSpace",
        "SweepGenerator",
        "TrialScheduler",
        "HPOTuner",
        "EarlyStopper",
        "NASEngine"
      ]
    },
    {
      "name": "pipeline",
      "description": "工作流编排：声明 DAG、缓存中间产物、按策略重试",
      "injects_into": [
        "configure",
        "prepare_data",
        "build_model",
        "train",
        "verify",
        "compress",
        "deploy"
      ],
      "components": [
        "WorkflowScheduler",
        "TaskDAG",
        "PipelineCache",
        "RetryPolicy"
      ]
    },
    {
      "name": "test",
      "description": "CI 与合并前门禁处运行的测试与质量门槛",
      "injects_into": [
        "verify"
      ],
      "components": [
        "UnitTest",
        "IntegrationTest",
        "RegressionTest",
        "QualityGate"
      ]
    }
  ],
  "modules": [
    {
      "name": "test",
      "description": "测试体系：单元、集成、回归与质量门禁",
      "components": [
        {
          "name": "IntegrationTest",
          "description": "用于端到端跑通训练-评估-导出流程",
          "imports": [
            "WorkflowScheduler",
            "Reporter"
          ],
          "exports": [
            "integration_test"
          ]
        },
        {
          "name": "RegressionTest",
          "description": "用于在 CI 上对比新旧模型的指标回归",
          "imports": [
            "Reporter"
          ],
          "optional": true,
          "exports": [
            "regression_test"
          ]
        },
        {
          "name": "QualityGate",
          "description": "用于在合并前对模型设置最低指标门槛",
          "imports": [
            "Reporter"
          ],
          "optional": true,
          "exports": [
            "quality_gate"
          ]
        }
      ]
    }
  ]
}
