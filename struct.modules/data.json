{
  "schema_version": "3.0",
  "description": "Simple Model — 多任务/多模态项目架构：模块定义、调用关系、数据流",
  "conventions": {
    "depends_on": "该服务直接调用的上游服务列表（仅记录直接调用，不展开传递依赖）",
    "produces": "该服务产出的核心 artifact / 数据，串联起来即完整数据流",
    "optional": "true 表示按需启用的扩展服务，false 或缺省为核心服务",
    "pipeline.stages": "按 order 升序执行的顺序阶段，构成完整训练-部署的 happy path",
    "pipeline.cross_cutting": "横切关注点：不参与主流程串行顺序，而是在多个阶段并行注入",
    "supported_tasks": "架构显式支持的任务清单，是 Auto* 派发的依据"
  },
  "phases": [
    {
      "phase": "configure",
      "order": 1,
      "mode": "sequential",
      "description": "加载并校验配置，按任务名拉取 AutoConfig",
      "core_components": [
        "ConfigLoader",
        "ConfigComposer",
        "ConfigValidator",
        "TaskRegistry",
        "AutoConfig"
      ]
    },
    {
      "phase": "prepare_data",
      "order": 2,
      "mode": "sequential",
      "description": "按任务拉取 Processor，加载、解析、切分、组装 batch",
      "core_components": [
        "AutoProcessor",
        "DataLoader",
        "DataParser",
        "DataSplitter",
        "Tokenizer",
        "ImageProcessor",
        "AudioFeatureExtractor",
        "Collator"
      ],
      "optional_components": [
        "DataCleaner",
        "VideoProcessor",
        "DataAugmenter",
        "DataCache",
        "DataVersion"
      ]
    },
    {
      "phase": "build_model",
      "order": 3,
      "mode": "sequential",
      "description": "按任务从 ModelRegistry 拉取 Backbone+Neck+Head，组装模型与优化器",
      "core_components": [
        "AutoModel",
        "ModelRegistry",
        "Backbone",
        "Neck",
        "Head",
        "ModelBuilder",
        "LossFunction",
        "Optimizer",
        "LRScheduler"
      ]
    },
    {
      "phase": "init_distributed",
      "order": 4,
      "mode": "select_one",
      "description": "按配置挑选一种分布式后端初始化进程组",
      "core_components": [
        "ClusterMonitor",
        "RankSync"
      ],
      "select_one_of": [
        "DDPLauncher",
        "FSDPManager",
        "DeepSpeedEngine",
        "TensorParallel"
      ]
    },
    {
      "phase": "train",
      "order": 5,
      "mode": "sequential",
      "description": "训练主循环，含混合精度、梯度管理、EMA、回调与检查点",
      "core_components": [
        "Trainer",
        "MixedPrecision",
        "Callback",
        "Checkpoint"
      ],
      "optional_components": [
        "GradientAccumulator",
        "GradientClipper",
        "EMA"
      ]
    },
    {
      "phase": "verify",
      "order": 6,
      "mode": "sequential",
      "description": "按任务路由到对应指标集并生成报告",
      "core_components": [
        "Validator",
        "TaskEvaluator",
        "MetricsCalculator",
        "Reporter"
      ],
      "optional_components": [
        "NLPMetrics",
        "VisionMetrics",
        "SpeechMetrics",
        "RankingMetrics",
        "GenerationMetrics",
        "Benchmark",
        "RobustnessProbe"
      ]
    },
    {
      "phase": "compress",
      "order": 7,
      "mode": "select_subset",
      "description": "按需执行量化、剪枝、蒸馏、图优化并导出跨平台格式",
      "core_components": [
        "Exporter"
      ],
      "select_subset_of": [
        "Quantizer",
        "Pruner",
        "Distiller",
        "GraphOptimizer"
      ]
    },
    {
      "phase": "deploy",
      "order": 8,
      "mode": "sequential",
      "description": "上线推理服务、暴露 API、灰度发布并接入漂移监控",
      "core_components": [
        "InferenceEngine",
        "ModelServer",
        "APIGateway"
      ],
      "optional_components": [
        "CanaryDeployer",
        "DriftDetector"
      ]
    }
  ],
  "cross_cutting": [
    {
      "name": "tracking",
      "description": "贯穿全程的实验追踪、产物记录与可视化",
      "injects_into": [
        "configure",
        "train",
        "verify",
        "compress",
        "deploy"
      ],
      "components": [
        "ExperimentTracker",
        "MetricRecorder",
        "ArtifactStore",
        "Visualizer"
      ]
    },
    {
      "name": "repro",
      "description": "贯穿全程的可复现性保障：种子、环境快照、依赖锁、审计",
      "injects_into": [
        "configure",
        "prepare_data",
        "train",
        "verify"
      ],
      "components": [
        "SeedManager",
        "EnvSnapshot",
        "AuditLogger"
      ]
    },
    {
      "name": "profile",
      "description": "在 train 与 deploy 阶段按需启用的性能与显存分析",
      "injects_into": [
        "train",
        "deploy"
      ],
      "default_enabled": false,
      "components": [
        "Profiler",
        "MemoryProfiler",
        "BottleneckAnalyzer"
      ]
    },
    {
      "name": "hpo",
      "description": "外层循环：包裹 configure→train→verify，按 trial 反复执行挑选最优超参",
      "injects_into": [
        "train",
        "verify"
      ],
      "default_enabled": false,
      "components": [
        "SearchSpace",
        "SweepGenerator",
        "TrialScheduler",
        "HPOTuner",
        "EarlyStopper",
        "NASEngine"
      ]
    },
    {
      "name": "pipeline",
      "description": "工作流编排：声明 DAG、缓存中间产物、按策略重试",
      "injects_into": [
        "configure",
        "prepare_data",
        "build_model",
        "train",
        "verify",
        "compress",
        "deploy"
      ],
      "components": [
        "WorkflowScheduler",
        "TaskDAG",
        "PipelineCache",
        "RetryPolicy"
      ]
    },
    {
      "name": "test",
      "description": "CI 与合并前门禁处运行的测试与质量门槛",
      "injects_into": [
        "verify"
      ],
      "components": [
        "UnitTest",
        "IntegrationTest",
        "RegressionTest",
        "QualityGate"
      ]
    }
  ],
  "modules": [
    {
      "name": "data",
      "description": "数据导入、预处理、增强、缓存与版本管理，含任务相关 Processor",
      "components": [
        {
          "name": "DataLoader",
          "description": "用于从各类数据源（文件/数据库/对象存储）导入数据",
          "exports": [
            "raw_samples"
          ],
          "imports": [],
          "todos": [
            {
              "task": "实现文件路径批量加载（CSV/JSONL/Parquet）",
              "priority": "high",
              "id": "data_loader_1",
              "status": "done",
              "blocks": [
                "data_parser_1"
              ]
            },
            {
              "task": "支持 S3 / OSS / GCS 对象存储后端",
              "priority": "medium",
              "id": "data_loader_2",
              "status": "done"
            },
            {
              "task": "实现流式迭代器，避免一次性载入全量数据",
              "priority": "high",
              "id": "data_loader_3",
              "status": "done"
            }
          ]
        },
        {
          "name": "DataParser",
          "description": "用于解析原始数据并转换为统一格式",
          "exports": [
            "parsed_dataset"
          ],
          "imports": [
            "DataLoader"
          ],
          "todos": [
            {
              "task": "定义统一的 schema（features / label / meta）",
              "priority": "high",
              "id": "data_parser_1",
              "status": "done",
              "blocks": [
                "data_splitter_1",
                "tokenizer_1"
              ]
            },
            {
              "task": "实现 schema 校验与缺失字段告警",
              "priority": "medium",
              "id": "data_parser_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "DataCleaner",
          "description": "用于清洗数据中的噪声、缺失值和异常点",
          "exports": [
            "clean_dataset"
          ],
          "imports": [
            "DataParser"
          ],
          "optional": true
        },
        {
          "name": "DataSplitter",
          "description": "用于划分训练集、验证集和测试集",
          "exports": [
            "train_split",
            "val_split",
            "test_split"
          ],
          "imports": [
            "DataParser"
          ],
          "todos": [
            {
              "task": "支持随机切分与 stratified 切分",
              "priority": "high",
              "id": "data_splitter_1",
              "status": "done"
            },
            {
              "task": "支持按 group / 时间 / 客户等业务键切分",
              "priority": "medium",
              "id": "data_splitter_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "Tokenizer",
          "description": "用于 NLP 文本的子词切分与 ID 映射（BPE / WordPiece / SentencePiece）",
          "exports": [
            "token_ids",
            "attention_mask"
          ],
          "imports": [],
          "todos": [
            {
              "task": "对接 HuggingFace tokenizers，支持 BPE/WordPiece/SP",
              "priority": "high",
              "id": "tokenizer_1",
              "status": "done"
            },
            {
              "task": "实现 batch 编码（truncation / padding / max_length）",
              "priority": "high",
              "id": "tokenizer_2",
              "status": "done"
            },
            {
              "task": "支持 special tokens 与 chat template",
              "priority": "medium",
              "id": "tokenizer_3",
              "status": "done"
            }
          ]
        },
        {
          "name": "ImageProcessor",
          "description": "用于图像的 resize / normalize / 色彩空间 / 几何变换",
          "exports": [
            "image_tensor"
          ],
          "imports": [],
          "todos": [
            {
              "task": "实现 torchvision / albumentations 两种后端",
              "priority": "high",
              "id": "image_processor_1",
              "status": "done"
            },
            {
              "task": "支持多尺度训练（multi-scale crop）",
              "priority": "medium",
              "id": "image_processor_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "AudioFeatureExtractor",
          "description": "用于音频的 log-mel / 频谱 / fbank 特征提取",
          "exports": [
            "audio_features"
          ],
          "imports": [],
          "todos": [
            {
              "task": "实现 torchaudio / librosa 两套后端",
              "priority": "medium",
              "id": "audio_feature_extractor_1",
              "status": "done"
            },
            {
              "task": "支持 chunked 处理长音频",
              "priority": "medium",
              "id": "audio_feature_extractor_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "VideoProcessor",
          "description": "用于视频的帧采样、解码与时空增强",
          "exports": [
            "video_tensor"
          ],
          "imports": [
            "ImageProcessor"
          ],
          "todos": [
            {
              "task": "实现 decord / PyAV 两种解码后端",
              "priority": "medium",
              "id": "video_processor_1",
              "status": "done"
            },
            {
              "task": "实现 uniform / random / keyframe 多种采样策略",
              "priority": "medium",
              "id": "video_processor_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "Collator",
          "description": "用于把多条样本组装成 batch，处理 padding / attention mask / 序列对齐",
          "exports": [
            "batch"
          ],
          "imports": [
            "Tokenizer",
            "ImageProcessor",
            "AudioFeatureExtractor"
          ],
          "todos": [
            {
              "task": "实现多模态 batch 拼装（图+文+音对齐）",
              "priority": "high",
              "id": "collator_1",
              "status": "done"
            },
            {
              "task": "支持动态 padding 减少浪费",
              "priority": "medium",
              "id": "collator_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "DataAugmenter",
          "description": "用于对训练数据进行增强（Mixup / CutMix / RandAug / TokenMask ...）",
          "exports": [
            "augmented_batch"
          ],
          "imports": [
            "DataSplitter",
            "ImageProcessor",
            "Tokenizer"
          ],
          "optional": true
        },
        {
          "name": "DataCache",
          "description": "用于将预处理结果缓存到本地或分布式存储以加速迭代",
          "exports": [
            "cached_dataset"
          ],
          "imports": [
            "DataParser",
            "DataCleaner"
          ],
          "optional": true
        },
        {
          "name": "DataVersion",
          "description": "用于数据集的版本管理与血缘追踪（DVC / LakeFS）",
          "exports": [
            "dataset_version_pointer"
          ],
          "imports": [
            "DataCache"
          ],
          "optional": true
        }
      ]
    }
  ]
}
