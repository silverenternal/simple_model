{"$schema":"https://json-schema.org/draft/2020-12/schema","title":"Macro Certificate v1","type":"object","additionalProperties":false,"required":["schema_version","macro_id","certified","trusted","apply_mode_allowed","certificate_hash","signature","proof_obligations","remediation","inputs"],"properties":{"schema_version":{"const":"1.0"},"macro_id":{"type":"string"},"certified":{"type":"boolean"},"trusted":{"type":"boolean"},"apply_mode_allowed":{"type":"boolean"},"certificate_hash":{"type":"string","pattern":"^[a-f0-9]{64}$"},"signature":{"type":"object","required":["algorithm","signer","value"]},"proof_obligations":{"type":"array"},"remediation":{"type":"array"},"inputs":{"type":"object","required":["macro_hash","fixture_hash","content_hash"]}},"invariants":["A certificate is content-addressed over macro and fixture hashes.","Any failed obligation makes trusted and apply_mode_allowed false.","Remediation names the exact failed obligation and a deterministic next action."]}
