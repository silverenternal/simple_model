{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simple-model.local/semantic-interface-ir.json",
  "title": "simple_model Semantic Interface IR",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "root", "struct", "summary", "nodes"],
  "properties": {
    "schema_version": { "const": "2.0" },
    "root": { "type": "string" },
    "struct": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["nodes", "symbols", "routes", "contracts", "events", "jobs", "configs"],
      "properties": {
        "nodes": { "type": "integer", "minimum": 0 },
        "symbols": { "type": "integer", "minimum": 0 },
        "routes": { "type": "integer", "minimum": 0 },
        "contracts": { "type": "integer", "minimum": 0 },
        "events": { "type": "integer", "minimum": 0 },
        "jobs": { "type": "integer", "minimum": 0 },
        "configs": { "type": "integer", "minimum": 0 }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "kind", "name", "visibility", "path", "component", "module", "parser", "confidence", "hash", "evidence"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string" },
          "name": { "type": "string" },
          "visibility": { "type": "string" },
          "signature": { "type": "string" },
          "path": { "type": "string" },
          "line_start": { "type": "integer", "minimum": 0 },
          "line_end": { "type": "integer", "minimum": 0 },
          "module": { "type": "string" },
          "component": { "type": "string" },
          "parser": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "hash": { "type": "string" },
          "contract_refs": { "type": "array", "items": { "type": "string" } },
          "evidence": { "type": "object" }
        }
      }
    }
  }
}
