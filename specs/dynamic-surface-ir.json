{
  "schema_version": "1.0",
  "title": "Dynamic Surface IR",
  "type": "object",
  "required": ["schema_version", "ok", "summary", "nodes"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "ok": { "type": "boolean" },
    "root": { "type": "string" },
    "struct": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["nodes", "dynamic_known", "dynamic_observed", "dynamic_unverified", "dynamic_unsafe"],
      "properties": {
        "nodes": { "type": "integer", "minimum": 0 },
        "dynamic_known": { "type": "integer", "minimum": 0 },
        "dynamic_observed": { "type": "integer", "minimum": 0 },
        "dynamic_unverified": { "type": "integer", "minimum": 0 },
        "dynamic_unsafe": { "type": "integer", "minimum": 0 },
        "generated_files": { "type": "integer", "minimum": 0 },
        "env_keys": { "type": "integer", "minimum": 0 }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "name",
          "path",
          "line",
          "evidence",
          "resolver",
          "confidence",
          "risk_level",
          "verification_status"
        ],
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "enum": [
              "route",
              "di_binding",
              "plugin_registration",
              "event_subscription",
              "dynamic_import",
              "reflection",
              "monkey_patch",
              "generated_interface",
              "env_gate",
              "config_gate",
              "job_registration",
              "unsafe_execution"
            ]
          },
          "name": { "type": "string" },
          "path": { "type": "string" },
          "line": { "type": "integer", "minimum": 0 },
          "module": { "type": "string" },
          "component": { "type": "string" },
          "evidence": { "type": "object" },
          "resolver": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "risk_level": {
            "enum": ["dynamic_known", "dynamic_observed", "dynamic_unverified", "dynamic_unsafe"]
          },
          "verification_status": {
            "enum": ["static_inferred", "observed", "probe_gap", "unsafe"]
          },
          "semantic_links": { "type": "array" },
          "hash": { "type": "string" }
        }
      }
    }
  }
}
