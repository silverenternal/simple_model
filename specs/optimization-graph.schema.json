{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simple-model.local/optimization-graph.schema.json",
  "title": "simple_model Optimization Graph",
  "type": "object",
  "required": ["schema_version", "ok", "summary", "nodes", "edges"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "ok": { "type": "boolean" },
    "root": { "type": "string" },
    "struct": { "type": "string" },
    "graph_hash": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": { "type": "integer", "minimum": 0 },
        "edges": { "type": "integer", "minimum": 0 },
        "components": { "type": "integer", "minimum": 0 },
        "macro_candidates": { "type": "integer", "minimum": 0 },
        "dynamic_surfaces": { "type": "integer", "minimum": 0 },
        "tests": { "type": "integer", "minimum": 0 }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "name", "hash", "evidence"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string" },
          "name": { "type": "string" },
          "path": { "type": "string" },
          "component": { "type": "string" },
          "module": { "type": "string" },
          "hash": { "type": "string" },
          "score_weight": { "type": "number" },
          "risk": { "type": "string" },
          "evidence": { "type": "object" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "from", "to", "kind", "hash", "evidence"],
        "properties": {
          "id": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "kind": { "type": "string" },
          "hash": { "type": "string" },
          "evidence": { "type": "object" }
        }
      }
    }
  }
}
