{
  "schema_version": "2.0",
  "required": ["pack_id", "version", "source", "build_inputs", "certificates", "adapters", "dependencies", "permissions", "content_hash", "signatures", "provenance"],
  "policy": {
    "unsigned_mode": "inspect_only",
    "tampered_mode": "deny_simulate_and_apply",
    "offline_verification": true,
    "revocation_required": true
  },
  "signature": {
    "algorithm": "sha256-keyed-envelope",
    "canonicalization": "jq-sort-keys",
    "key_rotation": true
  }
}
